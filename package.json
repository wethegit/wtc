{
  "name": "homebrew-wtc",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "lint": "oxlint",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check": "tsc --noEmit",
    "test": "bun test",
    "prepare": "husky",
    "build": "bun run scripts/build.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^0.15.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.3.4",
    "yargs": "^18.0.0",
    "zod": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt --check"
    ]
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
