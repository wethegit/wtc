{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "error",
    "no-undef": "error",
    "typescript": {
      "no-explicit-any": "error",
      "no-non-null-assertion": "warn",
      "prefer-as-const": "error",
      "prefer-function-type": "error"
    }
  }
}
